rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if the current user is an admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Users can access their own data, Admins can access EVERYTHING
    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      
      // Prevent users from making themselves admins or changing their subscription
      allow create: if request.auth.uid == userId 
        && !request.resource.data.keys().hasAny(['isAdmin', 'subscription']);
      
      allow update: if request.auth.uid == userId 
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'subscription']))
        || isAdmin();

      allow delete: if isAdmin(); // Only admins can delete accounts

      // Subcollections (resumes, profile)
      match /{subcollection}/{docId} {
        allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      }
    }

    // Allow admins to list users
    match /users {
      allow list: if isAdmin();
    }

    // Email subscribers — anyone can subscribe (used by the email capture modal)
    match /email_subscribers/{emailId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Feedback — authenticated users can submit, admins can manage
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // Referrals — users can manage their own referral data
    match /referrals/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }

    // Referral code lookups — read-only for code validation
    match /referral_codes/{code} {
      allow read: if true;
      allow write: if request.auth != null || isAdmin();
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
